@using MatchBetting.ViewModels.Admin
@model AdminDashboardViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-11">

            <div class="p-4 rounded-3 border bg-light mb-4">
                <h2 class="fw-bold mb-1">Admin</h2>
                <p class="text-muted mb-0">
                    Enkel drift av tippekonken.
                </p>
            </div>

            @if (TempData["AdminMessage"] != null)
            {
                <div class="alert alert-info">
                    @TempData["AdminMessage"]
                </div>
            }

            <div class="row g-3 mb-4">
                <div class="col-6 col-md-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="text-muted small">Brukarar</div>
                            <div class="h3 mb-0">@Model.UserCount</div>
                        </div>
                    </div>
                </div>

                <div class="col-6 col-md-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="text-muted small">Utan gruppe</div>
                            <div class="h3 mb-0">@Model.UsersWithoutGroupCount</div>
                        </div>
                    </div>
                </div>

                <div class="col-6 col-md-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="text-muted small">Kampar</div>
                            <div class="h3 mb-0">@Model.MatchCount</div>
                        </div>
                    </div>
                </div>

                <div class="col-6 col-md-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="text-muted small">Spelarar</div>
                            <div class="h3 mb-0">@Model.PlayerCount</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-4 shadow-sm">
                <div class="card-body">
                    <div class="d-flex flex-column flex-md-row justify-content-between gap-2 mb-3">
                        <div>
                            <h5 class="fw-bold mb-1">Sidebet-fasit</h5>
                            <p class="text-muted mb-0">
                                Legg inn fasit manuelt når turneringa er ferdig. Sidebets tel 3 poeng per korrekt svar.
                            </p>
                        </div>

                        @if (Model.SideBetResultUpdatedAtUtc != null)
                        {
                            <div class="text-muted small">
                                Sist lagra: @Model.SideBetResultUpdatedAtUtc.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                            </div>
                        }
                    </div>

                    <form action="@Url.Action("SaveSideBetResult", "Admin")" method="post">
                        @Html.AntiForgeryToken()

                        <div class="row g-3">
                            <div class="col-12 col-md-4">
                                <label class="form-label fw-semibold">Toppscorar</label>
                                <input name="toppscorer"
                                       class="form-control"
                                       value="@Model.SideBetResultToppscorer"
                                       placeholder="T.d. Kylian Mbappé" />
                                <div class="form-text">
                                    Kan hentast frå Football-Data når turneringa er ferdig.
                                </div>
                            </div>

                            <div class="col-12 col-md-4">
                                <label class="form-label fw-semibold">Vinnarlag</label>
                                <input name="winnerTeam"
                                       class="form-control"
                                       value="@Model.SideBetResultWinnerTeam"
                                       placeholder="T.d. Frankrike" />
                            </div>

                            <div class="col-12 col-md-4">
                                <label class="form-label fw-semibold">Mest kort</label>
                                <input name="mostCards"
                                       class="form-control"
                                       value="@Model.SideBetResultMostCards"
                                       placeholder="T.d. Argentina" />
                                <div class="form-text">
                                    Ver konsekvent: bruk lag dersom det er lag brukarane har tippa på.
                                </div>
                            </div>
                        </div>

                        <div class="mt-3 d-flex flex-column flex-md-row gap-2">
                            <button type="submit"
                                    class="btn btn-success"
                                    onclick="return confirm('Lagre sidebet-fasit?');">
                                Lagre sidebet-fasit
                            </button>

                            <span class="text-muted small align-self-md-center">
                                Dette lagrar fasiten i databasen. Poengutrekning blir kobla på seinare.
                            </span>
                        </div>
                    </form>

                    <hr />

                    <form action="@Url.Action("FetchTopScorerFromFootballData", "Admin")" method="post">
                        @Html.AntiForgeryToken()

                        <div class="d-flex flex-column flex-md-row gap-2">
                            <button type="submit"
                                    class="btn btn-outline-primary"
                                    onclick="return confirm('Hente toppscorar frå Football-Data og overskrive toppscorar-feltet?');">
                                Hent toppscorar frå Football-Data
                            </button>

                            <span class="text-muted small align-self-md-center">
                                Hentar toppscorar for VM 2026 frå Football-Data og lagrar namnet i toppscorar-feltet.
                                Dersom API-konfig manglar, feilar berre denne handlinga, ikkje admin-sida.
                            </span>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card mb-4 shadow-sm">
                <div class="card-body">
                    <h5 class="fw-bold">Vedlikehald</h5>

                    <div class="d-flex flex-column flex-md-row gap-2">
                        <form action="@Url.Action("SeedPlayers", "Admin")" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-primary">
                                Synk spelarar frå NIFS
                            </button>
                        </form>

                        <form action="@Url.Action("FixNullSideBets", "Admin")" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-secondary">
                                Fiks tomme sidebets
                            </button>
                        </form>
                    </div>

                    <hr />

                    <form action="@Url.Action("AddPlayer", "Admin")" method="post" class="row g-2">
                        @Html.AntiForgeryToken()
                        <div class="col-12 col-md-8">
                            <input name="name"
                                   class="form-control"
                                   placeholder="Legg til spelar manuelt, t.d. Martin Ødegaard" />
                        </div>
                        <div class="col-12 col-md-4">
                            <button type="submit" class="btn btn-outline-primary w-100">
                                Legg til spelar
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="fw-bold">Brukarar</h5>

                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Namn</th>
                                    <th>E-post</th>
                                    <th>Gruppe</th>
                                    <th class="text-center">Tips</th>
                                    <th class="text-center">Sidebet</th>
                                    <th style="width: 320px;">Endre gruppe</th>
                                    <th style="width: 280px;">Nytt passord</th>
                                    <th style="width: 120px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in Model.Users)
                                {
                                    var displayName = string.IsNullOrWhiteSpace(user.FullName)
                                        ? user.Email ?? user.UserName ?? user.UserId
                                        : user.FullName;

                                    <tr>
                                        <td class="fw-semibold">
                                            @(string.IsNullOrWhiteSpace(user.FullName) ? "-" : user.FullName)
                                        </td>

                                        <td>
                                            @(user.Email ?? "-")
                                        </td>

                                        <td>
                                            @(user.CompetitionGroupName ?? "Ingen gruppe")
                                        </td>

                                        <td class="text-center">
                                            @user.MatchBetCount
                                        </td>

                                        <td class="text-center">
                                            @(user.HasSideBet ? "Ja" : "Nei")
                                        </td>

                                        <td>
                                            <form action="@Url.Action("SetUserGroup", "Admin")" method="post" class="d-flex gap-2">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@user.UserId" />

                                                <select name="competitionGroupId" class="form-select form-select-sm">
                                                    <option value="">Ingen gruppe</option>
                                                    @foreach (var group in Model.Groups)
                                                    {
                                                        if (user.CompetitionGroupId?.ToString() == group.Value)
                                                        {
                                                            <option value="@group.Value" selected>@group.Text</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@group.Value">@group.Text</option>
                                                        }
                                                    }
                                                </select>

                                                <button type="submit" class="btn btn-sm btn-outline-primary">
                                                    Lagre
                                                </button>
                                            </form>
                                        </td>

                                        <td>
                                            <form action="@Url.Action("ResetPassword", "Admin")" method="post" class="d-flex gap-2">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@user.UserId" />

                                                <input name="newPassword"
                                                       type="text"
                                                       class="form-control form-control-sm"
                                                       placeholder="Nytt passord"
                                                       minlength="4"
                                                       autocomplete="off" />

                                                <button type="submit"
                                                        class="btn btn-sm btn-outline-secondary"
                                                        onclick="return confirm('Setje nytt passord for @displayName?');">
                                                    Set
                                                </button>
                                            </form>
                                        </td>

                                        <td>
                                            <form action="@Url.Action("DeleteUser", "Admin")" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@user.UserId" />

                                                <button type="submit"
                                                        class="btn btn-sm btn-outline-danger"
                                                        onclick="return confirm('Slette brukaren og alle tips/sidebets?');">
                                                    Slett
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="text-muted small">
                        Sletting fjernar brukaren, kamp-tips og sidebets.
                        Bruk gruppeendring dersom du berre vil skjule gamle deltakarar frå leaderboard.
                        Passordreset set nytt passord direkte for brukaren.
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>