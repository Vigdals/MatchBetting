@using MatchBetting.ViewModels
@model List<global::MatchBetting.ViewModels.LeaderBoardByUserViewModel>?

@{
    Layout = "~/Pages/Shared/_Layout.cshtml";
    var currentMatches = ViewBag.CurrentMatches as List<MatchViewModel> ?? new List<MatchViewModel>();
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12">

            <div class="p-4 rounded-3 border bg-light mb-4">
                <div class="d-flex flex-column flex-md-row align-items-center gap-3 text-center text-md-start">
                    <img src="~/img/worldcup-2026.png"
                         alt="2026 FIFA World Cup Emblem"
                         class="img-fluid"
                         style="max-width: 90px; height: auto;" />

                    <div>
                        <h2 class="fw-bold mb-1">Historikk</h2>
                        <p class="mb-0 text-muted">
                            Tidlegare VM 2026-kampar og tipping i di gruppe.
                        </p>
                    </div>
                </div>
            </div>

            @if (Model == null || !Model.Any())
            {
                <div class="alert alert-info">
                    Det finst ingen deltakarar enno.
                </div>
            }
            else if (!currentMatches.Any())
            {
                <div class="alert alert-info">
                    Ingen VM 2026-kampar er ferdigspelte enno.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover table-bordered align-middle">
                        <thead>
                            <tr>
                                <th>Deltakar</th>
                                <th class="text-center">P</th>

                                @foreach (var match in currentMatches)
                                {
                                    <th title="@match.MatchId" class="text-center small">
                                        <div>
                                            <img src="@match.HomeTeamLogoUrl"
                                                 alt="@match.HomeTeam"
                                                 width="16"
                                                 height="16"
                                                 id="HomeTeamLogo_@match.MatchId" />
                                            @match.HomeTeam
                                        </div>
                                        <div>
                                            <img src="@match.AwayTeamLogoUrl"
                                                 alt="@match.AwayTeam"
                                                 width="16"
                                                 height="16"
                                                 id="AwayTeamLogo_@match.MatchId" />
                                            @match.AwayTeam
                                        </div>
                                        <div class="fw-bold">
                                            @match.HomeScore90 - @match.AwayScore90
                                        </div>
                                    </th>
                                }
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var user in Model.OrderByDescending(o => o.Score).ThenBy(o => o.UserName))
                            {
                                <tr>
                                    <td class="fw-bold">@user.UserName</td>
                                    <td class="fw-bold text-center">@user.Score</td>

                                    @foreach (var match in currentMatches)
                                    {
                                        var betting = user.CurrentBettings.FirstOrDefault(b => b.MatchId == match.MatchId);

                                        if (betting == null || string.IsNullOrWhiteSpace(betting.Result))
                                        {
                                            <td title="@match.MatchId" class="text-center text-muted">-</td>
                                        }
                                        else
                                        {
                                            var resultClass = match.Result == betting.Result
                                                ? "text-success fw-bold"
                                                : "text-danger fw-bold";

                                            <td title="@betting.MatchId" class="@resultClass text-center">
                                                @betting.Result
                                            </td>
                                        }
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

        </div>
    </div>
</div>