@using MatchBetting.ViewModels
@model List<global::MatchBetting.ViewModels.AllSideBettingsViewModel>?

@{
    Layout = "~/Pages/Shared/_Layout.cshtml";
    var sideBetDeadline = ViewBag.SideBetDeadline as DateTime?;
    var isAdminPreview = ViewBag.IsAdminPreview as bool? ?? false;
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">

            <div class="p-4 rounded-3 border bg-light mb-4">
                <div class="d-flex flex-column flex-md-row align-items-center gap-3 text-center text-md-start">
                    <img src="~/img/worldcup-2026.png"
                         alt="2026 FIFA World Cup Emblem"
                         class="img-fluid"
                         style="max-width: 90px; height: auto;" />

                    <div>
                        <h2 class="fw-bold mb-1">Sidebets</h2>
                        <p class="mb-0 text-muted">
                            Toppscorar, vinnarlag og spelaren med flest kort.
                        </p>
                    </div>
                </div>
            </div>

            @if (Model == null || !Model.Any())
            {
                <div class="alert alert-info">
                    <h5 class="alert-heading">Sidebets er ikkje synlege enno</h5>
                    <p class="mb-1">
                        Sidebets blir synlege for alle når fristen har gått ut.
                    </p>

                    @if (sideBetDeadline != null)
                    {
                        <p class="mb-0">
                            Frist: <strong>@sideBetDeadline.Value.ToString("dd.MM.yyyy HH:mm")</strong>
                        </p>
                    }
                </div>
            }
            else
            {
                @if (isAdminPreview)
                {
                    <div class="alert alert-warning">
                        <strong>Adminvising:</strong>
                        Du ser sidebets før fristen fordi du har admintilgang.
                        Vanlege brukarar får ikkje sjå denne lista før fristen har gått ut.
                    </div>
                }
                else
                {
                    <div class="alert alert-success">
                        Sidebets er låst og synlege for gruppa.
                    </div>
                }

                <div class="card shadow-sm">
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped table-hover table-bordered align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Deltakar</th>
                                        <th>Toppscorar</th>
                                        <th>Vinnarlag</th>
                                        <th>Mest kort</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var user in Model.OrderBy(u => u.UserName))
                                    {
                                        var sideBet = user.CurrentSideBettings.FirstOrDefault();

                                        <tr>
                                            <td class="fw-semibold">@user.UserName</td>
                                            <td>@(string.IsNullOrWhiteSpace(sideBet?.Toppscorer) ? "-" : sideBet.Toppscorer)</td>
                                            <td>@(string.IsNullOrWhiteSpace(sideBet?.WinnerTeam) ? "-" : sideBet.WinnerTeam)</td>
                                            <td>@(string.IsNullOrWhiteSpace(sideBet?.MostCards) ? "-" : sideBet.MostCards)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }

        </div>
    </div>
</div>