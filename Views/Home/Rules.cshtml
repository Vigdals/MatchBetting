@{
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">

            <!-- HERO -->
            <div class="p-4 p-md-5 rounded-3 border bg-light mb-4">
                <div class="d-flex flex-column flex-md-row align-items-center gap-3 text-center text-md-start">

                    <div>
                        <img src="~/img/worldcup-2026.png"
                             class="img-fluid"
                             style="max-width: 90px; height: auto;" />
                    </div>
                    <div>
                        <h2 class="fw-bold mb-1">Reglar</h2>
                        <p class="mb-0 text-muted">
                            Slik fungerer tipping og poengsystemet
                        </p>
                    </div>

                </div>
            </div>

            <!-- TIPPING -->
            <div class="card mb-4 shadow-sm">
                <div class="card-body">
                    <h5 class="fw-bold">Tipping</h5>
                    <ul class="mb-0">
                        <li>Tipping på kampar må gjerast <strong>seinast 2 timar før kampstart</strong>.</li>
                        <li>Du kan endre tips heilt fram til 2t før kampstart.</li>
                        <li>I alle kampar tippar ein på resultat etter <strong>90 minutt</strong>.</li>
                    </ul>
                </div>
            </div>

            <!-- SIDEBETS -->
            <div class="card mb-4 shadow-sm">
                <div class="card-body">
                    <h5 class="fw-bold">Sidebets (ikkje aktivt no)</h5>
                    <ul class="mb-0">
                        <li>Toppscorar</li>
                        <li>Flest kort (gult = 1, raudt = 2)</li>
                        <li>Vinnarlag</li>
                    </ul>

                    <div class="mt-2 text-muted small">
                        Sidebets må settast før første kamp i turneringa.
                    </div>
                </div>
            </div>

            <!-- POENG -->
            <div class="card mb-4 shadow-sm">
                <div class="card-body">
                    <h5 class="fw-bold">Poengsystem</h5>
                    <ul class="mb-0">
                        <li><strong>1 poeng</strong> for rett H/U/B per kamp</li>
                        <li><strong>3 poeng</strong> for kvar korrekt sidebet</li>
                    </ul>
                </div>
            </div>

            <!-- RESULTAT -->
            <div class="card mb-4 shadow-sm">
                <div class="card-body">
                    <h5 class="fw-bold">Resultat og vinnar</h5>
                    <ul class="mb-0">
                        <li>Den med flest poeng vinn.</li>
                        <li>Ved lik poengsum vil premie delast eller avgjerast etter eigne reglar. Stein, saks, papir eller slåstkamp</li>
                    </ul>
                </div>
            </div>

        </div>
    </div>
</div>

<partial name="_ValidationScriptsPartial" />