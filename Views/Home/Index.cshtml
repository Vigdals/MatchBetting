@using MatchBetting.ViewModels
@model List<MatchBetting.ViewModels.NifsKampViewModel>?

@{
    Layout = "~/Pages/Shared/_Layout.cshtml";

    var osloTimeZone = TimeZoneInfo.FindSystemTimeZoneById("W. Europe Standard Time");
    var now = TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, osloTimeZone);

    var worldCupStart = new DateTime(2026, 06, 11, 21, 00, 00);

    // Sidebets blir låst 2 timar før første kamp.
    var deadline = new DateTime(2026, 06, 11, 19, 00, 00);
    var disabled = now >= deadline ? "disabled" : "";

    // Sluttspel opnar for tipping etter gruppespelet.
    var knockoutOpenTime = new DateTime(2026, 06, 28, 06, 00, 00);
    var knockoutEnabled = now >= knockoutOpenTime;

    var groupMatches = Model?.Where(m => m.phase == "group") ?? Enumerable.Empty<NifsKampViewModel>();
    var knockoutMatches = Model?.Where(m => m.phase == "knockout") ?? Enumerable.Empty<NifsKampViewModel>();

    string TeamLogo(string? logoUrl)
    {
        if (string.IsNullOrWhiteSpace(logoUrl))
        {
            return Url.Content("~/img/worldcup-2026.png");
        }

        if (logoUrl.StartsWith("~/"))
        {
            return Url.Content(logoUrl);
        }

        return logoUrl;
    }

    var fallbackLogo = Url.Content("~/img/worldcup-2026.png");
}

<div class="container py-3">

    <!-- HERO -->
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">

            <div class="p-3 rounded-3 border bg-light">
                <div class="d-flex align-items-center gap-3 flex-wrap">
                    <img src="~/img/worldcup-2026.png"
                         alt="VM 2026"
                         style="width: 70px; height: auto;" />

                    <div class="flex-grow-1">
                        <h1 class="h4 fw-bold mb-1">VM 2026</h1>

                        <div class="text-muted small mb-1">
                            Legg inn tippingane dine før fristen
                        </div>

                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <span class="text-muted small">Frist:</span>
                            <span id="wc-countdown" class="fw-semibold"></span>
                            <span class="badge text-bg-secondary">Tippekonk</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-muted small mt-1">
                Tipping blir låst 2 timar før kampstart.
            </div>

        </div>
    </div>

    <!-- SIDEBETS -->
    <div class="row justify-content-center mt-3">
        <div class="col-12 col-lg-10">
            <h4 class="mb-3">Sidebets</h4>

            <div class="row g-3">

                <div class="col-md-4">
                    <div class="card h-100">
                        <div class="card-body position-relative">
                            <label class="form-label fw-semibold">Toppscorar</label>

                            <input id="Toppscorer"
                                   class="form-control"
                                   placeholder="Søk spelar..."
                                   autocomplete="off"
                                   @disabled />

                            <div id="toppscorer-results"
                                 class="list-group position-absolute w-100 mt-1"
                                 style="z-index:1000;"></div>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card h-100">
                        <div class="card-body position-relative">
                            <label class="form-label fw-semibold">Flest kort</label>

                            <input id="Mostcards"
                                   class="form-control"
                                   placeholder="Søk spelar..."
                                   autocomplete="off"
                                   @disabled />

                            <div id="mostcards-results"
                                 class="list-group position-absolute w-100 mt-1"
                                 style="z-index:1000;"></div>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card h-100">
                        <div class="card-body position-relative">
                            <label class="form-label fw-semibold">Vinnar</label>

                            <input id="Winnerteam"
                                   class="form-control"
                                   placeholder="Søk lag..."
                                   autocomplete="off"
                                   @disabled />

                            <div id="winnerteam-results"
                                 class="list-group position-absolute w-100 mt-1"
                                 style="z-index:1000;"></div>
                        </div>
                    </div>
                </div>

            </div>

            <div class="mt-3">
                @if (string.IsNullOrWhiteSpace(disabled))
                {
                    <button id="SideBetButton" class="btn btn-success">
                        Lagre sidebets
                    </button>
                }
                else
                {
                    <span class="text-muted">Sidebet er låst.</span>
                }
            </div>
        </div>
    </div>

    <!-- MATCHES -->
    <div class="row justify-content-center mt-3">
        <div class="col-12 col-lg-10">

            @if (Model != null)
            {
                <!-- GROUP STAGE -->
                @foreach (var round in groupMatches.Select(m => m.round).Distinct().OrderBy(r => r))
                {
                    <h3 class="mt-4">Runde @round</h3>

                    <table class="table table-striped table-hover align-middle betting-table">
                        <colgroup>
                            <col class="date-col" />
                            <col class="team-col" />
                            <col class="pick-col" />
                            <col class="team-col" />
                        </colgroup>

                        <tbody>
                            @foreach (var item in groupMatches.Where(m => m.round == round).OrderBy(o => o.date))
                            {
                                var active = item.date.AddHours(-2) >= now ? "" : "disabled";

                                <tr>
                                    <td class="date-col">
                                        @item.date.ToString("dd.MM HH:mm")
                                    </td>

                                    <td class="team-cell">
                                        <img src="@TeamLogo(item.HomeTeamLogoUrl)"
                                             class="team-logo me-1"
                                             alt="@item.homeTeam"
                                             onerror="this.onerror=null;this.src='@fallbackLogo';" />
                                        @item.homeTeam
                                    </td>

                                    <td class="pick-cell">
                                        <div class="pick-options">
                                            <input type="radio"
                                                   name="match_@item.id"
                                                   value="H"
                                                   data-id="@item.id"
                                                   @active />

                                            <input type="radio"
                                                   name="match_@item.id"
                                                   value="U"
                                                   data-id="@item.id"
                                                   @active />

                                            <input type="radio"
                                                   name="match_@item.id"
                                                   value="B"
                                                   data-id="@item.id"
                                                   @active />
                                        </div>
                                    </td>

                                    <td class="team-cell">
                                        <img src="@TeamLogo(item.AwayTeamLogoUrl)"
                                             class="team-logo me-1"
                                             alt="@item.awayTeam"
                                             onerror="this.onerror=null;this.src='@fallbackLogo';" />
                                        @item.awayTeam
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }

                <!-- KNOCKOUT -->
                @if (knockoutMatches.Any())
                {
                    <h3 class="mt-5">Sluttspel</h3>

                    @if (!knockoutEnabled)
                    {
                        <div class="alert alert-info">
                            Sluttspel opnar for tipping 28. juni kl 06:00.
                        </div>
                    }

                    @foreach (var round in knockoutMatches.Select(m => m.round).Distinct().OrderBy(r => r))
                    {
                        <h4 class="mt-4">Runde @round</h4>

                        <table class="table table-striped table-hover align-middle betting-table">
                            <colgroup>
                                <col class="date-col" />
                                <col class="team-col" />
                                <col class="pick-col" />
                                <col class="team-col" />
                            </colgroup>

                            <tbody>
                                @foreach (var item in knockoutMatches.Where(m => m.round == round).OrderBy(o => o.date))
                                {
                                    var isMatchOpen = item.date.AddHours(-2) >= now;
                                    var active = knockoutEnabled && isMatchOpen ? "" : "disabled";

                                    <tr class="@(!knockoutEnabled ? "disabled-row" : "")">
                                        <td class="date-col">
                                            @item.date.ToString("dd.MM HH:mm")
                                        </td>

                                        <td class="team-cell">
                                            <img src="@TeamLogo(item.HomeTeamLogoUrl)"
                                                 class="team-logo me-1"
                                                 alt="@item.homeTeam"
                                                 onerror="this.onerror=null;this.src='@fallbackLogo';" />
                                            @item.homeTeam
                                        </td>

                                        <td class="pick-cell">
                                            <div class="pick-options">
                                                <input type="radio"
                                                       name="match_@item.id"
                                                       value="H"
                                                       data-id="@item.id"
                                                       @active />

                                                <input type="radio"
                                                       name="match_@item.id"
                                                       value="U"
                                                       data-id="@item.id"
                                                       @active />

                                                <input type="radio"
                                                       name="match_@item.id"
                                                       value="B"
                                                       data-id="@item.id"
                                                       @active />
                                            </div>
                                        </td>

                                        <td class="team-cell">
                                            <img src="@TeamLogo(item.AwayTeamLogoUrl)"
                                                 class="team-logo me-1"
                                                 alt="@item.awayTeam"
                                                 onerror="this.onerror=null;this.src='@fallbackLogo';" />
                                            @item.awayTeam
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                }
            }

        </div>
    </div>
</div>

@section Scripts {

    <script>
        let bettings = [];

        $(function () {
            GetCurrentUserBettings();
            GetCurrentUserSideBettings();

            $('#SideBetButton').on('click', UpdateSideBets);

            setupAutocomplete('#Toppscorer', '#toppscorer-results', '/Home/SearchPlayers');
            setupAutocomplete('#Mostcards', '#mostcards-results', '/Home/SearchPlayers');
            setupAutocomplete('#Winnerteam', '#winnerteam-results', '/Home/SearchTeams');
        });

        $(document).on("change", "input[type=radio]", function () {
            const id = $(this).data("id");
            const value = $(this).val();

            $.post("/Home/UpdateStorage", {
                matchId: id,
                result: value
            })
                .done(r => {
                    if (!r.success) {
                        alert(r.message || 'Klarte ikkje å lagre tippinga.');
                    }
                })
                .always(GetCurrentUserBettings);
        });

        function GetCurrentUserBettings() {
            $.get("/Home/GetCurrentUserBettings")
                .done(r => {
                    if (r.success) {
                        bettings = r.bettings;
                        UpdateBettingTable();
                    }
                });
        }

        function UpdateBettingTable() {
            $("input[type=radio]").prop("checked", false);

            bettings.forEach(b => {
                $(`input[name='match_${b.matchId}'][value='${b.result}']`).prop("checked", true);
            });
        }

        function UpdateSideBets() {
            const button = $('#SideBetButton');
            button.prop('disabled', true);

            $.post("/Home/UpdateSideBets", {
                Toppscorer: $('#Toppscorer').val(),
                MostCards: $('#Mostcards').val(),
                WinnerTeam: $('#Winnerteam').val()
            })
                .done(r => {
                    if (!r.success) {
                        alert(r.message || 'Klarte ikkje å lagre sidebets.');
                        return;
                    }

                    alert('Sidebets er lagra.');
                })
                .fail(() => alert('Klarte ikkje å lagre sidebets.'))
                .always(() => button.prop('disabled', false));
        }

        function GetCurrentUserSideBettings() {
            $.get("/Home/GetCurrentUserSideBettings")
                .done(r => {
                    if (r.success) {
                        $('#Toppscorer').val(r.sideBettings.toppscorer);
                        $('#Winnerteam').val(r.sideBettings.winnerTeam);
                        $('#Mostcards').val(r.sideBettings.mostCards);
                    }
                });
        }

        function setupAutocomplete(inputSelector, resultsSelector, url) {
            let debounceTimer;

            $(inputSelector).on('input', function () {
                clearTimeout(debounceTimer);

                const q = $(this).val();
                const container = $(resultsSelector);

                if (!q || q.length < 2) {
                    container.empty();
                    return;
                }

                debounceTimer = setTimeout(() => {
                    $.get(url, { q })
                        .done(results => {
                            container.empty();

                            if (!results?.length) return;

                            results.forEach(name => {
                                const item = $('<button type="button" class="list-group-item list-group-item-action"></button>');
                                item.text(name);

                                item.on('click', function () {
                                    $(inputSelector).val(name);
                                    container.empty();
                                });

                                container.append(item);
                            });
                        });
                }, 200);
            });
        }

        $(document).on('click', function (e) {
            if (!$(e.target).closest('#Toppscorer, #toppscorer-results').length) {
                $('#toppscorer-results').empty();
            }

            if (!$(e.target).closest('#Mostcards, #mostcards-results').length) {
                $('#mostcards-results').empty();
            }

            if (!$(e.target).closest('#Winnerteam, #winnerteam-results').length) {
                $('#winnerteam-results').empty();
            }
        });

        (function () {
            const target = new Date("@deadline.ToString("yyyy-MM-ddTHH:mm:ss")");

            function tick() {
                const el = document.getElementById("wc-countdown");
                if (!el) return;

                const diff = target - new Date();

                if (diff <= 0) {
                    el.innerText = "VM ER I GANG!";
                    return;
                }

                const d = Math.floor(diff / 86400000);
                const h = Math.floor((diff / 3600000) % 24);
                const m = Math.floor((diff / 60000) % 60);
                const s = Math.floor((diff / 1000) % 60);

                el.innerText = `${d} dagar ${h}t ${m}m ${s}s`;
            }

            tick();
            setInterval(tick, 1000);
        })();
    </script>
}