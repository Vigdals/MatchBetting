@using System.Globalization
@model List<MatchBetting.ViewModels.NifsKampViewModel>?

@{
    Layout = "~/Pages/Shared/_Layout.cshtml";
    var worldCupStart = new DateTime(2026, 06, 11, 02, 00, 00, DateTimeKind.Utc);
    var deadline = new DateTime(2026, 06, 11, 00, 00, 00);
    var now = TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow,
        TimeZoneInfo.FindSystemTimeZoneById("W. Europe Standard Time"));
    var disabled = now > deadline ? "disabled" : "";
}

<div class="container py-3">

    <!-- HERO -->
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">
            <div class="p-4 p-md-5 rounded-3 border bg-light">
                <div class="row align-items-center g-4">
                    <div class="col-12 col-md-3 text-center">
                        <img src="~/img/2026_FIFA_World_Cup_emblem.svg (1).png" alt="VM 2026"
                             class="img-fluid d-block mx-auto" style="max-width: 140px; height: auto;" />
                    </div>
                    <div class="col-12 col-md-9">
                        <h1 class="display-6 fw-bold mb-1">VM 2026</h1>
                        <p class="lead mb-3">Legg inn tippingane dine før fristen.</p>
                        <div class="d-flex flex-wrap gap-3 align-items-end">
                            <div>
                                <div class="text-muted small">FRIST:</div>
                                <div id="wc-countdown" class="fw-bold" style="font-size: 2rem; line-height: 1.1;"></div>
                            </div>
                            <div class="ms-md-auto">
                                <span class="badge text-bg-secondary">Tippekonk</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="text-muted small mt-2">Tipping blir låst 2 timar før kampstart.</div>
        </div>
    </div>

    <!-- TIPPING (React) -->
    <div class="row justify-content-center mt-3">
        <div class="col-12 col-lg-10">
            <div id="tipping-app"></div>

            <!-- SIDEBET -->
            <h4 class="mt-5">SideBet</h4>
            <hr />
            <div class="row">
                <div class="col-md-6 col-lg-5">
                    <div class="form-group">
                        <label class="control-label">Toppscorar</label>
                        <input asp-for="Toppscorer" class="form-control input_sidebet" id="Toppscorer" @disabled />
                    </div>
                    <div class="form-group mt-2">
                        <label class="control-label">Flest gule kort</label>
                        <input asp-for="MostCards" class="form-control input_sidebet" id="Mostcards" @disabled />
                    </div>
                    <div class="form-group mt-2">
                        <label class="control-label">Vinnarlag</label>
                        <input asp-for="WinnerTeam" class="form-control input_sidebet" id="Winnerteam" @disabled />
                    </div>
                    <div class="form-group mt-3">
                        @if (string.IsNullOrWhiteSpace(disabled))
                        {
                            <button class="btn btn-primary" id="SideBetButton">Lagre sidebet!</button>
                        }
                        else
                        {
                            <span class="text-muted small">Sidebet er låst.</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/react@18/umd/react.development.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>
    <script src="https://unpkg.com/@@babel/standalone/babel.min.js"></script>

    <script type="text/babel">
        const { useState, useEffect } = React;

        function BetButton({ label, selected, disabled, onClick }) {
            const style = selected ? "btn btn-sm fw-bold px-3 btn-success" : "btn btn-sm fw-bold px-3 btn-outline-secondary";
            return <button className={style} disabled={disabled} onClick={onClick}>{label}</button>;
        }

        function MatchRow({ match, savedBet, onBet, now }) {
            const locked = new Date(match.lockTime) <= now;
            const saved = savedBet?.result;
            return (
                <tr className={locked ? "text-muted" : ""}>
                    <td style={{whiteSpace: "nowrap"}}>
                        {new Date(match.date).toLocaleString("nb-NO", {day:"2-digit", month:"2-digit", hour:"2-digit", minute:"2-digit"})}
                    </td>
                    <td>
                        {match.homeTeamLogo && <img src={match.homeTeamLogo} width={16} height={16} className="me-1"/>}
                        {match.homeTeam}
                    </td>
                    <td className="text-center">
                        <div className="d-flex gap-1 justify-content-center">
                            {locked
                                ? <span className="badge bg-secondary">Låst</span>
                                : ["H","U","B"].map(val => (
                                    <BetButton key={val} label={val} selected={saved === val}
                                        onClick={() => onBet(match.id, val, saved)} />
                                ))
                            }
                        </div>
                    </td>
                    <td>
                        {match.awayTeamLogo && <img src={match.awayTeamLogo} width={16} height={16} className="me-1"/>}
                        {match.awayTeam}
                    </td>
                </tr>
            );
        }

        function RoundTable({ round, matches, bets, onBet, now }) {
            return (
                <div>
                    <h4 className="mt-4 mb-2">Runde {round}</h4>
                    <div className="table-responsive">
                        <table className="table table-striped table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Dato</th>
                                    <th>Heimelag</th>
                                    <th className="text-center">Tip</th>
                                    <th>Bortelag</th>
                                </tr>
                            </thead>
                            <tbody>
                                {matches
                                    .filter(m => m.round === round && m.gruppe !== "sluttspill")
                                    .sort((a, b) => new Date(a.date) - new Date(b.date))
                                    .map(m => (
                                        <MatchRow key={m.id} match={m}
                                            savedBet={bets.find(b => b.matchId === m.id)}
                                            onBet={onBet} now={now} />
                                    ))
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            );
        }

        function TippingApp() {
            const [matches, setMatches] = useState([]);
            const [bets, setBets] = useState([]);
            const now = new Date();

            useEffect(() => {
                fetch("/Home/GetMatchesForReact").then(r => r.json()).then(setMatches);
                fetch("/Home/GetCurrentUserBettings").then(r => r.json())
                    .then(d => { if (d.success) setBets(d.bettings); });
            }, []);

            async function handleBet(matchId, value, currentBet) {
                if (currentBet === value) {
                    await fetch("/Home/RemoveStorage", {
                        method: "POST",
                        headers: {"Content-Type": "application/x-www-form-urlencoded"},
                        body: `matchId=${matchId}`
                    });
                    setBets(prev => prev.filter(b => b.matchId !== matchId));
                } else {
                    await fetch("/Home/UpdateStorage", {
                        method: "POST",
                        headers: {"Content-Type": "application/x-www-form-urlencoded"},
                        body: `matchId=${matchId}&result=${value}`
                    });
                    setBets(prev => [...prev.filter(b => b.matchId !== matchId), { matchId, result: value }]);
                }
            }

            const rounds = [...new Set(matches.map(m => m.round))].filter(r => r > 0 && r < 5).sort();
            if (!matches.length) return <div className="alert alert-info mt-3">Lastar kampar...</div>;

            return (
                <div>
                    {rounds.map(r => (
                        <RoundTable key={r} round={r} matches={matches} bets={bets} onBet={handleBet} now={now} />
                    ))}
                </div>
            );
        }

        ReactDOM.createRoot(document.getElementById("tipping-app")).render(<TippingApp />);
    </script>

    <script>
        // Sidebet
        $(function () {
            GetCurrentUserSideBettings();
            $('#SideBetButton').click(UpdateSideBets);
        });

        function UpdateSideBets() {
            $.post("/Home/UpdateSideBets", {
                Toppscorer: $('#Toppscorer').val(),
                MostCards: $('#Mostcards').val(),
                WinnerTeam: $('#Winnerteam').val()
            }).done(r => { if (r.success) $('.input_sidebet').addClass("fade-green"); });
        }

        function GetCurrentUserSideBettings() {
            $.get("/Home/GetCurrentUserSideBettings").done(r => {
                if (r.success) {
                    $('#Toppscorer').val(r.sideBettings.toppscorer);
                    $('#Winnerteam').val(r.sideBettings.winnerTeam);
                    $('#Mostcards').val(r.sideBettings.mostCards);
                }
            });
        }

        // Nedtelling
        (function () {
            const target = new Date("@worldCupStart.ToString("yyyy-MM-ddTHH:mm:ssZ")");
            function pad(n) { return String(n).padStart(2, "0"); }
            function tick() {
                const el = document.getElementById("wc-countdown");
                if (!el) return;
                const diff = target - new Date();
                if (diff <= 0) { el.innerText = "VM ER I GANG!"; return; }
                const d = Math.floor(diff / 86400000);
                const h = Math.floor((diff / 3600000) % 24);
                const m = Math.floor((diff / 60000) % 60);
                const s = Math.floor((diff / 1000) % 60);
                el.innerText = `${d} dagar ${pad(h)}timar ${pad(m)}min ${pad(s)}sek`;
            }
            tick();
            setInterval(tick, 1000);
        })();
    </script>
}