@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
    var worldCupStart = new DateTime(2026, 06, 11, 02, 00, 00, DateTimeKind.Utc);
}

<div class="row">
    <div class="row justify-content-center">
        <div class="col-md-4">

            <!-- HERO / COUNTDOWN -->
            <div class="d-flex align-items-center gap-3 p-3 rounded-3 border bg-light mb-4">
                <img src="~/img/worldcup-2026.png" alt="VM 2026" style="width: 50px; height: auto;"/>
                <div>
                    <h5 class="fw-bold mb-0">VM 2026</h5>
                    <div class="text-muted small">Startar om <span id="wc-countdown" class="fw-semibold text-dark"></span></div>
                </div>
                <span class="badge text-bg-secondary ms-auto">Tippekonk</span>
            </div>


            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <h2>Lag ny konto</h2>
                <hr/>
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com"/>
                    <label asp-for="Input.Email">Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.FullName" class="form-control" placeholder="Ola Nordmann"/>
                    <label asp-for="Input.FullName">Fullt namn</label>
                    <span asp-validation-for="Input.FullName" class="text-danger"></span>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password"/>
                    <label asp-for="Input.Password">Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password"/>
                    <label asp-for="Input.ConfirmPassword">Confirm Password</label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted" style="font-size: 14px;">Gruppe</label>
                    <select asp-for="SelectedCompetitionGroupId"
                            asp-items="Model.CompetitionGroups"
                            class="form-select form-select-lg">
                        <option value="">— Vel gruppe —</option>
                    </select>
                    <span asp-validation-for="SelectedCompetitionGroupId" class="text-danger" style="font-size: 13px;"></span>
                </div>
                <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-primary">Registrer</button>
            </form>
        </div>
        @*     <div class="col-md-6 col-md-offset-2">
        <section>
